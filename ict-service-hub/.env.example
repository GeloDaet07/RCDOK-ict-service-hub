# .env.local — ICT Service Hub
# Diocese of Kalookan
# Copy this file and fill in your actual values

# ============================================================
# SUPABASE (Required)
# Get from: https://supabase.com/dashboard/project/<id>/settings/api
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here  # KEEP PRIVATE

# ============================================================
# APP SETTINGS (Required)
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: NEXT_PUBLIC_APP_URL=https://ict.dioceseofkalookan.org

# ============================================================
# RESEND — Email Notifications (Required)
# Get from: https://resend.com → API Keys
# Free tier: 3,000 emails/month — sufficient for diocesan use
# ============================================================
RESEND_API_KEY=re_your_resend_api_key_here

# Verified "From" domain in Resend
# Must match your domain (configure DNS records in Resend dashboard)
RESEND_FROM_DOMAIN=dioceseofkalookan.org

# ICT admin email — receives new ticket alerts
ICT_ADMIN_EMAIL=ict@dioceseofkalookan.org

# ============================================================
# OPTIONAL — Upstash Redis (for production rate limiting)
# Replaces in-memory middleware rate limiter
# Free tier: 10,000 commands/day
# Get from: https://upstash.com
# ============================================================
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ============================================================
# NODE
# ============================================================
NODE_ENV=development
